# Copy to .env and adjust. compose.yaml reads these (all have safe defaults).

# Shared secret used to sign and verify JWTs across exercise-service and
# coach-service. Must be the same for both. Use 32+ bytes in production.
JWT_SECRET=dev-secret-change-me-in-production-please-32b

# LLM provider for the coach: auto | anthropic | ollama | fallback.
#   auto      -> Anthropic if ANTHROPIC_API_KEY is set, else fallback (default)
#   ollama    -> free, fully-local model (no key, no billing) — see below
#   fallback  -> deterministic planner only, no LLM
# The app works fully in any mode; without an LLM it uses the fallback planner.
COACH_PROVIDER=auto

# --- Anthropic (paid) ---
ANTHROPIC_API_KEY=
COACH_MODEL=claude-opus-4-8

# --- Ollama (free, local) ---
# Start it with:  docker compose --profile ollama up -d
# Pull a model once:  docker compose exec ollama ollama pull llama3.1
# Then set COACH_PROVIDER=ollama above.
OLLAMA_MODEL=llama3.1

COACH_USE_LLM=true
