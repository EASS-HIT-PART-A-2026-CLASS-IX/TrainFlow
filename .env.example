# Copy to .env and adjust. compose.yaml reads these (all have safe defaults).

# Shared secret used to sign and verify JWTs across exercise-service and
# coach-service. Must be the same for both. Use 32+ bytes in production.
JWT_SECRET=dev-secret-change-me-in-production-please-32b

# LLM provider for the coach: auto | gemini | anthropic | fallback.
#   auto      -> Gemini if GEMINI_API_KEY set, else Anthropic if ANTHROPIC_API_KEY
#                set, else deterministic fallback (default)
#   gemini    -> Google Gemini (recommended free cloud tier)
#   anthropic -> Anthropic Claude (paid)
#   fallback  -> deterministic planner only, no LLM
# The app works fully in any mode; without an LLM it uses the fallback planner.
COACH_PROVIDER=auto
COACH_USE_LLM=true

# --- Gemini (free cloud tier — recommended) ---
# Get a free key at https://aistudio.google.com/apikey (no billing required).
# To force Gemini, also set COACH_PROVIDER=gemini above. Leave the key blank to
# use the deterministic fallback planner. NEVER commit a real key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic (paid) ---
ANTHROPIC_API_KEY=
COACH_MODEL=claude-opus-4-8
